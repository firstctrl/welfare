{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@welfare/shared": ["packages/shared/src"],
      "@welfare/shared/*": ["packages/shared/src/*"]
    }
  },
  "include": [],
  "exclude": ["node_modules"]
}
